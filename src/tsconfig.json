{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/app",
    "rootDir": "..",
    "types": [],
    "paths": {
      "@script-type": [
        "../scripts/site/types.ts"
      ],
      "@delon/*": [
        "../packages/*"
      ],
      "@shared": [
        "./app/shared"
      ],
      "@core": [
        "./app/core/index"
      ]
    }
  },
  "include": ["**/*.ts", "../packages/dev-mode-types.d.ts"],
  "exclude": ["**/*.d.ts", "test.ts", "**/*.spec.ts", "templates/*.ts", "templates-v2/*.ts"]
}
