{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "baseUrl": "./",
    "rootDir": "./",
    "outDir": "../out-tsc/spec",
    "types": ["vitest/globals"],
    "paths": {
      "@delon/*": ["./*"]
    },
    "esModuleInterop": true,
    "noImplicitThis": false
  },
  "include": [
    "**/*.d.ts",
    "abc/**/*.spec.ts",
    "acl/**/*.spec.ts",
    "auth/**/*.spec.ts",
    "cache/**/*.spec.ts",
    "chart/**/*.spec.ts",
    "form/**/*.spec.ts",
    "mock/**/*.spec.ts",
    "theme/**/*.spec.ts",
    "util/**/*.spec.ts"
  ]
}
