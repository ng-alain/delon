{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "baseUrl": "./",
    "rootDir": "./",
    "outDir": "../out-tsc/spec",
    "types": [
      "vitest/globals"
    ],
    "paths": {
      "@delon/*": ["./*"]
    },
    "esModuleInterop": true,
    "noImplicitThis": false,
    "noImplicitAny": false,
    "strict": false,
    "skipLibCheck": true
  },
  "files": ["test-vi.ts"],
  "include": [
    "**/*.spec.ts",
    "**/*.d.ts"
  ],
  "exclude": [
    "node_modules"
  ],
  "angularCompilerOptions": {
    "enableIvy": true
  }
}
