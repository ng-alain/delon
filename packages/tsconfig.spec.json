{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "baseUrl": "./",
    "rootDir": "./",
    "outDir": "../out-tsc/spec",
    "types": ["jasmine"],
    "paths": {
      "@delon/*": ["./*"]
    },
    "esModuleInterop": true,
    "noImplicitThis": false
  },
  "files": ["test.ts"],
  "include": [
    "**/*.spec.ts",
    "**/*.d.ts"
  ],
  "exclude": [
    // Exclude all migrated spec files to avoid 'vi' is not defined errors in Karma
    "abc/**/*.spec.ts",
    "acl/**/*.spec.ts",
    "auth/**/*.spec.ts",
    "cache/**/*.spec.ts",
    "chart/**/*.spec.ts",
    "form/**/*.spec.ts",
    "mock/**/*.spec.ts",
    "theme/**/*.spec.ts",
    "util/**/*.spec.ts"
  ]
}
